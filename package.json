{
  "name": "dupla",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "start:dev": "pnpm --filter api run start:dev",
    "dev:web": "pnpm --filter web run dev",
