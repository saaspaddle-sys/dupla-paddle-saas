root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# En Markdown dos espacios al final de una línea son un salto de línea
# intencional — recortarlos rompe el renderizado.
[*.md]
trim_trailing_whitespace = false
